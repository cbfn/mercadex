meta {
  name: Create Category (Admin)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/categories
  body: json
  auth: none
}

headers {
  content-type: application/json
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "name": "Perifericos",
    "description": "Teclados, mouses e headsets"
  }
}

vars:pre-request {
  baseUrl: http://localhost:3001
}
