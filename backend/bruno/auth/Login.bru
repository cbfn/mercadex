meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}api/auth/login
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "email": "admin@mercadex.com",
    "password": "Admin123!"
  }
}

vars:pre-request {
  baseUrl: http://localhost:3001
}

script:post-response {
  if (res.status === 200 && res.body && res.body.data && res.body.data.accessToken) {
    bru.setVar("accessToken", res.body.data.accessToken);
  }
}
